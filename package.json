{
  "name": "openclaw-notion-ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generic Notion board operations wrapper for OpenClaw-style personal systems",
  "bin": {
    "notion-board-ops": "./notion-board-ops.mjs"
  },
  "scripts": {
    "help": "node ./notion-board-ops.mjs",
    "sync:openclaw": "node ./scripts/sync-to-openclaw.mjs",
    "sync:crons": "node ./scripts/sync-openclaw-crons.mjs",
    "sync:dashboards": "node ./scripts/sync-dashboards.mjs",
    "sync:all": "npm run sync:openclaw && npm run sync:dashboards && npm run sync:crons",
    "check:crons": "node ./scripts/sync-openclaw-crons.mjs --check",
    "check:live": "node ./scripts/check-live-state.mjs",
    "check:dashboards": "node ./scripts/check-dashboards.mjs",
    "audit:notion-ux": "node ./scripts/audit-notion-first-ux.mjs",
    "check:openclaw": "node ./scripts/check-live-state.mjs",
    "diff:openclaw": "bash ./scripts/diff-live.sh",
    "patch:telegram-poll-hook": "node ./scripts/patch-openclaw-telegram-poll-hook.mjs",
    "smoke:cron": "node ./scripts/smoke-cron-job.mjs",
    "smoke:morning": "node ./scripts/smoke-morning-cron.mjs",
    "smoke:evening": "node ./scripts/smoke-evening-cron.mjs",
    "smoke:weekly": "node ./scripts/smoke-weekly-cron.mjs",
    "smoke:monthly": "node ./scripts/smoke-monthly-cron.mjs",
    "smoke:yearly": "node ./scripts/smoke-yearly-cron.mjs",
    "smoke:eod-poll-build": "node ./scripts/smoke-eod-poll-build.mjs",
    "smoke:eod-poll-dry-run": "node ./scripts/smoke-eod-poll-dry-run.mjs",
    "smoke:eod-poll-process-preview": "node ./scripts/smoke-eod-poll-process-preview.mjs"
  },
  "engines": {
    "node": ">=18"
  }
}
